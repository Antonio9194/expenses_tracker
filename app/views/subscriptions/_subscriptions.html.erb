<div class="panel">
  <div class="panel-header">
    <div class="panel-title subscriptions-title">
      <span class="panel-icon"><i class="bi bi-arrow-repeat"></i></span>
      Subscriptions
    </div>
    <div class="panel-header-stat">
      <div class="panel-header-stat-label"><%= Date.today.strftime("%B %Y") %></div>
      <div class="panel-header-stat-value"><%= format_currency(@monthly_subscription_sum) %></div>
    </div>
    <%= link_to "+ New", new_subscription_path, class: "btn-new", data: { turbo_frame: "modal" } %>
  </div>
  <div class="panel-filters">
    <%= render "subscription_buttons" %>
  </div>
  <% if @subscriptions.any? %>
    <ul class="expense-list">
      <% @subscriptions.order(start_date: :desc).each do |sub| %>
        <li class="expense-item">
          <div class="expense-item-icon sub-icon-<%= sub.status %>">
            <i class="bi bi-arrow-repeat"></i>
          </div>
          <div class="expense-item-info">
            <div class="expense-item-title"><%= sub.title %></div>
            <div class="expense-item-sub"><%= sub.billing_cycle.humanize %> · <span class="tag tag-<%= sub.status %>"><%= sub.status.humanize %></span></div>
          </div>
          <div class="expense-item-right">
            <div class="expense-item-amount" style="color: var(--accent)"><%= format_currency(sub.amount) %></div>
            <div class="expense-item-actions">
              <%= link_to edit_subscription_path(sub), class: "btn-action btn-edit" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= link_to confirm_destroy_subscription_path(sub), class: "btn-action btn-delete", data: { turbo_frame: "modal" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="expense-list-footer">
      <span>Total</span>
      <span class="tfoot-total tfoot-total--accent"><%= format_currency(@monthly_subscription_sum) %></span>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-icon"><i class="bi bi-arrow-repeat"></i></div>
      <div>No subscriptions yet</div>
    </div>
  <% end %>
</div>
