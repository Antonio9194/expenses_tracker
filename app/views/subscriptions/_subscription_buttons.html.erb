<%= link_to "All",       subscriptions_path,                               class: "btn-filter #{params[:billing_cycle].blank? && params[:status].blank? ? 'active' : ''}" %>
<%= link_to "Weekly",   subscriptions_path(params.permit(:status).merge(billing_cycle: "weekly")),   class: "btn-filter #{params[:billing_cycle] == 'weekly'    ? 'active' : ''}" %>
<%= link_to "Monthly",  subscriptions_path(params.permit(:status).merge(billing_cycle: "monthly")),  class: "btn-filter #{params[:billing_cycle] == 'monthly'   ? 'active' : ''}" %>
<%= link_to "Yearly",   subscriptions_path(params.permit(:status).merge(billing_cycle: "yearly")),   class: "btn-filter #{params[:billing_cycle] == 'yearly'    ? 'active' : ''}" %>
<%= link_to "Active",   subscriptions_path(params.permit(:billing_cycle).merge(status: "active")),   class: "btn-filter #{params[:status] == 'active'    ? 'active' : ''}" %>
<%= link_to "Paused",   subscriptions_path(params.permit(:billing_cycle).merge(status: "paused")),   class: "btn-filter #{params[:status] == 'paused'    ? 'active' : ''}" %>
<%= link_to "Cancelled",subscriptions_path(params.permit(:billing_cycle).merge(status: "cancelled")),class: "btn-filter #{params[:status] == 'cancelled' ? 'active' : ''}" %>
