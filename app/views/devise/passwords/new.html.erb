<div class="form-page">
  <div class="form-card">
    <div class="form-card-header">
      <span class="form-card-icon icon-accent"><i class="bi bi-key"></i></span>
      <h2 class="form-card-title">Forgot your password?</h2>
    </div>

    <p class="form-subtitle">Enter your email and we'll send you reset instructions.</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "premium-form" }) do |f| %>
      <%= f.error_notification %>

      <div class="field-wrapper">
        <%= f.input :email, required: true, autofocus: true,
              input_html: { autocomplete: "email", class: "premium-input" },
              wrapper_html: { class: "field-wrapper" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Send reset instructions", class: "btn-submit" %>
      </div>
    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
