<div class="dashboard">
  <div class="dashboard-header dashboard-header-3col">
    <h1>All Expenses</h1>
    <nav class="header-center">
      <%= link_to "Dashboard", root_path, class: "btn-filter" %>
      <%= link_to "← Back", expenses_path, class: "btn-filter" %>
    </nav>
    <div class="header-right">
      <span class="header-meta"><%= Date.today.strftime("%B %d, %Y") %></span>
      <%= form_with url: update_currency_path, method: :patch, html: { class: "currency-switcher", "data-turbo" => "false" } do |f| %>
        <%= f.select :currency,
            [["$ USD", "USD"], ["€ EUR", "EUR"], ["£ GBP", "GBP"], ["¥ JPY", "JPY"], ["¥ CNY", "CNY"]],
            { selected: current_user.currency },
            { class: "currency-select", onchange: "this.form.submit()" } %>
      <% end %>
    </div>
  </div>
  <div class="panel-grid">
    <div class="panel">
      <div class="panel-header">
        <div class="panel-title expenses-title">
          <span class="panel-icon"><i class="bi bi-receipt"></i></span>
          All Expenses
        </div>
        <div class="panel-header-stat">
          <div class="panel-header-stat-label">
            <%= params[:month].present? ? Date.parse(params[:month]).strftime("%B %Y") : "All Time" %>
          </div>
          <div class="panel-header-stat-value"><%= format_currency(@expenses_sum) %></div>
        </div>
      </div>
      <div class="panel-filters history-filters">
        <%= form_with url: history_expenses_path, method: :get, class: "history-month-form" do |f| %>
          <%= f.select :month,
          [["All months", ""]] + @months.map { |m| [m.month.strftime("%B %Y"), m.month.strftime("%Y-%m-%d")] },
          { selected: params[:month] },
          { class: "history-month-select", onchange: "this.form.submit()" } %>
        <% end %>
      </div>
      <div class="panel-scroll">
        <% if @expenses.any? %>
          <table class="panel-table">
            <colgroup>
              <col class="col-title">
              <col class="col-secondary">
              <col class="col-secondary">
              <col class="col-amount">
              <col class="col-actions">
            </colgroup>
            <thead>
              <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Date</th>
                <th class="col-amount">Amount</th>
                <th class="col-actions">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @expenses.each do |expense| %>
                <tr>
                  <td><%= expense.title %></td>
                  <td><span class="tag tag-category"><%= expense.category.humanize %></span></td>
                  <td style="color: var(--text-muted)"><%= expense.date.strftime("%b '%y") %></td>
                  <td class="col-amount">
                    <span class="amount"><%= format_currency(expense.amount) %></span>
                  </td>
                  <td class="col-actions action-cell">
                    <%= link_to edit_expense_path(expense), class: "btn-action btn-edit", data: { turbo_frame: "modal" } do %>
                      <span class="btn-label">Edit</span><i class="bi bi-pencil btn-icon"></i>
                    <% end %>
                    <%= link_to confirm_destroy_expense_path(expense),
                                class: "btn-action btn-delete",
                                data: { turbo_frame: "modal" } do %>
                      <span class="btn-label">Delete</span><i class="bi bi-trash btn-icon"></i>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
            <tfoot>
              <tr>
                <td class="tfoot-label">Total</td>
                <td></td>
                <td></td>
                <td class="col-amount tfoot-total tfoot-total--danger"><%= format_currency(@expenses_sum) %></td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        <% else %>
          <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-receipt"></i></div>
            <div>No expenses found</div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>