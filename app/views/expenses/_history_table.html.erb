<div class="panel-grid">
  <div class="panel">
    <div class="panel-header">
      <div class="panel-title expenses-title">
        <span class="panel-icon"><i class="bi bi-receipt"></i></span>
        All Expenses
      </div>
      <div class="panel-header-stat">
        <div class="panel-header-stat-label">
          <%= params[:month].present? ? Date.parse(params[:month]).strftime("%B %Y") : "All Time" %>
        </div>
        <div class="panel-header-stat-value"><%= format_currency(@expenses_sum) %></div>
      </div>
    </div>
    <% if params[:month].present? %>
      <% snapshot = @monthly_snapshots.find { |s| s.month.strftime("%Y-%m-%d") == params[:month] } %>
      <% if snapshot %>
        <div class="snapshot-strip">
          <div class="snapshot-stat">
            <span class="stat-label">Budget</span>
            <span class="stat-value"><%= format_currency(snapshot.budget_amount) %></span>
          </div>
          <div class="snapshot-divider"></div>
          <div class="snapshot-stat">
            <span class="stat-label">Expenses</span>
            <span class="stat-value stat-value--danger"><%= format_currency(@expenses_sum) %></span>
          </div>
          <div class="snapshot-divider"></div>
          <div class="snapshot-stat">
            <span class="stat-label">Savings</span>
            <span class="stat-value <%= snapshot.savings >= 0 ? 'stat-value--accent' : 'stat-value--danger' %>">
              <%= format_currency(snapshot.savings) %>
            </span>
          </div>
        </div>
      <% end %>
    <% end %>
    <div class="panel-filters">
      <%= render "history_buttons" %>
    </div>
    <div class="panel-filters history-filters">
      <%= form_with url: history_expenses_path, method: :get, class: "history-month-form" do |f| %>
        <%= f.select :month,
          [["All months", ""]] + @months.map { |m| [m.month.strftime("%B %Y"), m.month.strftime("%Y-%m-%d")] },
          { selected: params[:month] },
          { class: "history-month-select", onchange: "this.form.submit()" } %>
      <% end %>
    </div>
    <% if @expenses.any? %>
      <ul class="expense-list">
        <% @expenses.each do |expense| %>
          <li class="expense-item">
            <div class="expense-item-icon expense-icon-<%= expense.category %>">
              <i class="bi <%= category_icon(expense.category) %>"></i>
            </div>
            <div class="expense-item-info">
              <div class="expense-item-title"><%= expense.title %></div>
              <div class="expense-item-sub"><%= expense.category.humanize %> · <%= expense.date.strftime("%b '%y") %></div>
            </div>
            <div class="expense-item-right">
              <div class="expense-item-amount"><%= format_currency(expense.amount) %></div>
              <div class="expense-item-actions">
                <%= link_to edit_expense_path(expense), class: "btn-action btn-edit", data: { turbo_frame: "modal" } do %>
                  <i class="bi bi-pencil"></i>
                <% end %>
                <%= link_to confirm_destroy_expense_path(expense), class: "btn-action btn-delete", data: { turbo_frame: "modal" } do %>
                  <i class="bi bi-trash"></i>
                <% end %>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
      <div class="expense-list-footer">
        <span>Total</span>
        <span class="tfoot-total tfoot-total--danger"><%= format_currency(@expenses_sum) %></span>
      </div>
    <% else %>
      <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-receipt"></i></div>
        <div>No expenses found</div>
      </div>
    <% end %>
  </div>
</div>
