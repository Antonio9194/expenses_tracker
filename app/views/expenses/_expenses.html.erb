<div class="panel">
  <div class="panel-header">
    <div class="panel-title expenses-title">
      <span class="panel-icon"><i class="bi bi-receipt"></i></span>
      Expenses
    </div>
    <div class="panel-header-stat"
      data-controller="stats-budget"
      data-stats-budget-monthly-expenses-value="<%= @monthly_expenses_sum %>"
      data-stats-budget-currency-value="<%= current_user.currency %>">
      <div class="panel-header-stat-label"><%= Date.today.strftime("%B %Y") %></div>
      <div class="panel-header-stat-value" data-stats-budget-target="monthlyExpenses"><%= format_currency(@monthly_expenses_sum) %></div>
    </div>
    <div class="panel-actions">
      <%= link_to history_expenses_path, class: "btn-history" do %>
        <span class="btn-label">History</span>
        <i class="bi bi-clock-history btn-icon"></i>
      <% end %>
      <%= link_to new_expense_path, class: "btn-new", data: { turbo_frame: "modal" } do %>
        <span class="btn-label">+ New</span>
        <i class="bi bi-plus btn-icon"></i>
      <% end %>
    </div>
  </div>
  <div class="panel-filters">
    <%= render "search_buttons" %>
  </div>
  <% if @monthly_expenses.any? %>
    <ul class="expense-list">
      <% @monthly_expenses.each do |expense| %>
        <li class="expense-item">
          <div class="expense-item-icon expense-icon-<%= expense.category %>">
            <i class="bi <%= category_icon(expense.category) %>"></i>
          </div>
          <div class="expense-item-info">
            <div class="expense-item-title"><%= expense.title %></div>
            <div class="expense-item-sub"><%= expense.category.humanize %> · <%= expense.date.strftime("%b %d") %></div>
          </div>
          <div class="expense-item-right">
            <div class="expense-item-amount"><%= format_currency(expense.amount) %></div>
            <div class="expense-item-actions">
              <%= link_to edit_expense_path(expense), class: "btn-action btn-edit", data: { turbo_frame: "modal" } do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= link_to confirm_destroy_expense_path(expense), class: "btn-action btn-delete", data: { turbo_frame: "modal" } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
    <div class="expense-list-footer">
      <span>Total</span>
      <span class="tfoot-total tfoot-total--danger"><%= format_currency(@monthly_expenses_sum) %></span>
    </div>
  <% else %>
    <div class="empty-state">
      <div class="empty-icon"><i class="bi bi-receipt"></i></div>
      <div>No expenses this month</div>
    </div>
  <% end %>
</div>
