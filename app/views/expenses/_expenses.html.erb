<div class="panel">
  <div class="panel-header">
    <div class="panel-title expenses-title">
      <span class="panel-icon"><i class="bi bi-receipt"></i></span>
      Expenses
    </div>
    <div class="panel-header-stat">
      <div class="panel-header-stat-label"><%= Date.today.strftime("%B %Y") %></div>
      <div class="panel-header-stat-value"><%= format_currency(@monthly_expenses) %></div>
    </div>
    <%= link_to "+ New", new_expense_path, class: "btn-new" %>
  </div>
  <div class="panel-filters">
    <%= render "search_buttons" %>
  </div>
  <div class="panel-scroll">
    <% if @expenses.any? %>
      <table class="panel-table">
        <colgroup>
          <col class="col-title">
          <col class="col-secondary">
          <col class="col-secondary">
          <col class="col-amount">
          <col class="col-actions">
        </colgroup>
        <thead>
          <tr>
            <th>Title</th>
            <th>Category</th>
            <th>Date</th>
            <th class="col-amount">Amount</th>
            <th class="col-actions">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @expenses.each do |expense| %>
            <tr>
              <td><%= expense.title %></td>
              <td><span class="tag tag-category"><%= expense.category.humanize %></span></td>
              <td style="color: var(--text-muted)"><%= expense.date.strftime("%b %d, %Y") %></td>
              <td class="col-amount">
                <span class="amount"><%= format_currency(expense.amount) %></span>
              </td>
              <td class="col-actions action-cell">
                <%= link_to "Edit", edit_expense_path(expense), class: "btn-action btn-edit" %>
                <%= button_to "Delete", expense_path(expense), method: :delete,
                          class: "btn-action btn-delete",
                          form: { class: "inline-form", data: { turbo_confirm: "Delete this expense?" } } %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr>
            <td>Total</td>
            <td></td>
            <td></td>
            <td class="col-amount"><%= format_currency(@monthly_expenses) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    <% else %>
      <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-receipt"></i></div>
        <div>No expenses this month</div>
      </div>
    <% end %>
  </div>
</div>
