<div class="dashboard">
  <!-- Header -->
  <div class="dashboard-header">
    <h1>Overview</h1>
    <span class="header-meta"><%= Date.today.strftime("%B %d, %Y") %></span>
  </div>
  <!-- Stats strip -->
  <div class="stats-strip">
    <div class="stats-row">
      <div class="stat-card stat-expenses">
        <div class="stat-label">Total Expenses</div>
        <div class="stat-value"><%= number_to_currency(@total_expenses) %></div>
      </div>
      <div class="stat-card stat-subscriptions">
        <div class="stat-label">Active Subscriptions</div>
        <div class="stat-value"><%= number_to_currency(@active_subscriptions_total) %></div>
      </div>
      <div class="stat-card stat-total">
        <div class="stat-label">Combined Total</div>
        <div class="stat-value"><%= number_to_currency(@combined_total) %></div>
      </div>
    </div>
    <div class="stats-row stats-row-center">
      <div class="stat-card">
        <div class="stat-label">Total Expenses for <%= Date.today.strftime("%B %Y") %></div>
        <div class="stat-value"><%= number_to_currency(@monthly_expenses) %></div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Total Active Subscriptions for <%= Date.today.strftime("%B %Y") %></div>
        <div class="stat-value"><%= number_to_currency(@monthly_subscription) %></div>
      </div>
    </div>
  </div>
  <!-- Two-column panel grid -->
  <div class="panel-grid">
    <!-- Expenses panel -->
    <%= render "expenses" %>
    <!-- Subscriptions panel -->
    <%= render "subscription" %>
  </div>
</div>
