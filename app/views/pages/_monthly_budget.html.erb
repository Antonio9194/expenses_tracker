<div class="budget-strip">
  <div class="budget-card <%= 'budget-enabled' if @budget.enabled? %>">
    <div class="budget-card-left">
      <span class="budget-card-label">Monthly Budget</span>
      <span class="budget-card-amount">
        <% if @budget.enabled? && @budget.amount.present? %>
          <%= format_currency(@budget.amount) %>
        <% else %>
          Not set
        <% end %>
      </span>
    </div>
    <div class="budget-card-right">
      <% if @budget.enabled? %>
        <%= link_to edit_budget_path, class: "budget-edit-link", data: { turbo_frame: "modal" } do %>
          <span class="btn-label">Edit</span>
          <i class="bi bi-pencil btn-icon"></i>
        <% end %>
      <% end %>
      <%= button_to toggle_budget_path,
              method: :patch,
              class: "budget-toggle #{@budget.enabled? ? 'budget-toggle--on' : ''}",
              form: { style: "display:inline" } do %>
        <span class="budget-toggle-track">
          <span class="budget-toggle-thumb"></span>
        </span>
      <% end %>
    </div>
  </div>
</div>